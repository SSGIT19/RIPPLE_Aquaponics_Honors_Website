@page "/faq"

@code {
    private HashSet<string> openItems = new();

    private void Toggle(string id)
    {
        if (openItems.Contains(id))
            openItems.Remove(id);
        else
            openItems.Add(id);
    }
}

<section class="faq-hero">
    <h1>Frequently Asked Questions</h1>
    <p>
        Have questions about Ripple, aquaponics, volunteering, or how our system works?
        You’re in the right place.
    </p>
</section>

<!-- GENERAL QUESTIONS -->
<section class="faq-section">
    <h2>General Questions</h2>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q1"))">
            What is Ripple?
        </button>
        @if (openItems.Contains("q1"))
        {
            <p class="faq-answer">
                Ripple is a community‑driven aquaponics initiative working to reduce food insecurity
                in the Chicagoland area through sustainable, year‑round food production.
            </p>
        }
    </div>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q2"))">
            What is aquaponics?
        </button>
        @if (openItems.Contains("q2"))
        {
            <p class="faq-answer">
                Aquaponics grows fish and plants together in a closed‑loop system. Fish produce nutrients
                for the plants, and the plants clean the water for the fish.
            </p>
        }
    </div>
</section>

<!-- FOOD & DISTRIBUTION -->
<section class="faq-section">
    <h2>Food & Distribution</h2>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q3"))">
            Is the food free?
        </button>
        @if (openItems.Contains("q3"))
        {
            <p class="faq-answer">
                Yes. Our produce and fish are distributed through local food pantries, shelters,
                and community partners at no cost to families.
            </p>
        }
    </div>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q4"))">
            What kinds of food do you grow?
        </button>
        @if (openItems.Contains("q4"))
        {
            <p class="faq-answer">
                We grow buttercrisp lettuce and other leafy greens, along with Nile tilapia — a hardy,
                nutritious freshwater fish.
            </p>
        }
    </div>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q5"))">
            Where does the food go?
        </button>
        @if (openItems.Contains("q5"))
        {
            <p class="faq-answer">
                We work with Chicagoland food pantries and community organizations to distribute food
                directly to neighborhoods facing food insecurity.
            </p>
        }
    </div>
</section>

<!-- FACILITY & SAFETY -->
<section class="faq-section">
    <h2>Facility & Safety</h2>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q6"))">
            Is the facility safe and clean?
        </button>
        @if (openItems.Contains("q6"))
        {
            <p class="faq-answer">
                Absolutely. We use strict biosecurity practices, daily water testing, and separate zones
                for fish, plants, and packaging to ensure food safety.
            </p>
        }
    </div>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q7"))">
            Do you use chemicals or pesticides?
        </button>
        @if (openItems.Contains("q7"))
        {
            <p class="faq-answer">
                No. Aquaponics relies on natural nutrient cycles, beneficial bacteria, and clean water —
                not chemical fertilizers or pesticides.
            </p>
        }
    </div>

    <div class="faq-item">
        <button class="faq-question" @onclick="@(() => Toggle("q8"))">
            Can I tour the facility?
        </button>
        @if (openItems.Contains("q8"))
        {
            <p class="faq-answer">
                Yes! We offer guided tours and educational workshops. Check our Get Involved page for
                upcoming opportunities.
            </p>
        }
    </div>
</section>

<!-- VOLUNTEERING & EDUCATION -->
<section class="faq-section">